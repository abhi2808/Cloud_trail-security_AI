# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/cloudtrail_ai?retryWrites=true&w=majority
JWT_SECRET=your_long_random_secret_min_32_chars_12345
JWT_EXPIRY_HOURS=24
ENCRYPTION_SECRET=your_base64_encoded_32_byte_fernet_key=

# AWS — Default region (User credentials are now stored encrypted in MongoDB, not here)
AWS_REGION=ap-south-1

# AWS Bedrock — backend-only credentials (NEVER used for CloudTrail/EC2/IAM reads)
BEDROCK_ACCESS_KEY_ID=your_bedrock_access_key_here
BEDROCK_SECRET_ACCESS_KEY=your_bedrock_secret_key_here
BEDROCK_REGION=ap-south-1
BEDROCK_MODEL_ID=apac.anthropic.claude-3-5-sonnet-20241022-v2:0

# App
PORT=8000
CLIENT_URL=http://localhost:5173
